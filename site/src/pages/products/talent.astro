---
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import i18n from '../../../../data/i18n/ja.yaml';
import talentLogo9to16 from '../../assets/products/talent/logo-9to16.svg';
import vocationsFigure from '../../assets/products/talent/header-part-1-chapter-1.png';
import languageFigure from '../../assets/products/talent/switch-language-ja-en.png';
import '../../styles/products/talent.css';

const p = i18n.products_talent;
---

<Layout title={p.layout.title} description={p.layout.description}>
  <article class="product-article">
    <header class="product-header reveal">
      <div class="col-wrap">
        <div class="product-header__grid">
          <div class="product-header__text">
            <p class="product-header__breadcrumb">
              <a href="/#products">{p.breadcrumb_label}</a>
              <span aria-hidden="true">/</span>
              <span>{p.header.title}</span>
            </p>
            <h1 class="product-header__title">{p.header.title}</h1>
            <p class="product-header__tagline">{p.header.tagline}</p>
            <div class="product-header__meta">
              <div><span>{p.header.meta.field_label}</span><strong>{p.header.meta.field_value}</strong></div>
              <div><span>{p.header.meta.distribution_label}</span><strong>{p.header.meta.distribution_value}</strong></div>
              <div><span>{p.header.meta.status_label}</span><strong>{p.header.meta.status_value}</strong></div>
            </div>
          </div>
          <Image
            src={talentLogo9to16}
            alt=""
            class="product-header__logo"
            loading="eager"
          />
        </div>
      </div>
    </header>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.overview.num}</p>
            <p class="marginalia">{p.overview.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.overview.title}</h2>
            <p class="section__paragraph" set:html={p.overview.paragraph_1}></p>
            <p class="section__paragraph" set:html={p.overview.paragraph_2}></p>
            <div class="callout">
              <p class="callout__label">{p.overview.callout.label}</p>
              <p class="callout__text" set:html={p.overview.callout.text}></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.etymology.num}</p>
            <p class="marginalia">{p.etymology.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.etymology.title}</h2>
            <p class="section__paragraph" set:html={p.etymology.paragraph_1}></p>
            <p class="section__paragraph" set:html={p.etymology.paragraph_2}></p>
            <div class="callout">
              <p class="callout__label">{p.etymology.callout.label}</p>
              <p class="callout__text" set:html={p.etymology.callout.text}></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.principles.num}</p>
            <p class="marginalia">{p.principles.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title" set:html={p.principles.title}></h2>
            <p class="section__paragraph">{p.principles.lede}</p>
            <ol class="principle-list">
              {p.principles.items.map((item: { num: string; title: string; text: string }) => (
                <li class="principle-list__item">
                  <span class="principle-list__num">{item.num}</span>
                  <div>
                    <h3 class="principle-list__title">{item.title}</h3>
                    <p class="principle-list__text" set:html={item.text}></p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.axes.num}</p>
            <p class="marginalia">{p.axes.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.axes.title}</h2>
            <div class="axes-grid">
              {p.axes.items.map((item: { num: string; title: string; text: string }) => (
                <div class="axes-grid__item">
                  <p class="axes-grid__num">{item.num}</p>
                  <h3 class="axes-grid__title">{item.title}</h3>
                  <p class="axes-grid__text">{item.text}</p>
                </div>
              ))}
            </div>
            <p class="section__paragraph section__paragraph--lift" set:html={p.axes.lift_text}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.curriculum.num}</p>
            <p class="marginalia">{p.curriculum.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.curriculum.title}</h2>
            <p class="section__paragraph" set:html={p.curriculum.paragraph}></p>
            <div class="category-list">
              {p.curriculum.categories.map((item: { tag: string; title: string; text: string }) => (
                <div class="category-list__item">
                  <p class="category-list__tag">{item.tag}</p>
                  <div>
                    <h3 class="category-list__title">{item.title}</h3>
                    <p class="category-list__text" set:html={item.text}></p>
                  </div>
                </div>
              ))}
            </div>
            <p class="section__paragraph section__paragraph--lift" set:html={p.curriculum.lift_text}></p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width: 30%">{p.curriculum.table.head_area}</th>
                    <th>{p.curriculum.table.head_body}</th>
                  </tr>
                </thead>
                <tbody>
                  {p.curriculum.rows.map((row: { area: string; body: string }) => (
                    <tr>
                      <td class="cell-strong">{row.area}</td>
                      <td>{row.body}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <h3 class="section__subtitle">{p.curriculum.rigor.subtitle}</h3>
            <p class="section__paragraph" set:html={p.curriculum.rigor.intro}></p>
            <div class="category-list">
              {p.curriculum.rigor.items.map((item: { tag: string; title: string; text: string }) => (
                <div class="category-list__item">
                  <p class="category-list__tag">{item.tag}</p>
                  <div>
                    <h3 class="category-list__title" set:html={item.title}></h3>
                    <p class="category-list__text" set:html={item.text}></p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.vocations.num}</p>
            <p class="marginalia">{p.vocations.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.vocations.title}</h2>
            <p class="section__paragraph" set:html={p.vocations.paragraph}></p>
            <figure class="product-section__figure">
              <Image src={vocationsFigure} alt={p.vocations.figure_alt} loading="lazy" />
            </figure>
            <div class="category-list">
              {p.vocations.items.map((item: { tag: string; title: string; text: string }) => (
                <div class="category-list__item">
                  <p class="category-list__tag">{item.tag}</p>
                  <div>
                    <h3 class="category-list__title">{item.title}</h3>
                    <p class="category-list__text">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
            <p class="section__paragraph section__paragraph--lift" set:html={p.vocations.lift_text}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.safety.num}</p>
            <p class="marginalia">{p.safety.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.safety.title}</h2>
            <ul class="check-list">
              {p.safety.check_items.map((item: string) => <li set:html={item}></li>)}
            </ul>

            <h3 class="section__subtitle" set:html={p.safety.subtitle}></h3>
            <p class="section__paragraph">{p.safety.subtitle_paragraph}</p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width: 22%">{p.safety.table.head_standard}</th>
                    <th>{p.safety.table.head_area}</th>
                  </tr>
                </thead>
                <tbody>
                  {p.safety.standards.map((std: { name: string; href: string; text: string }) => (
                    <tr>
                      <td class="cell-strong"><a href={std.href} target="_blank" rel="noopener">{std.name}</a></td>
                      <td>{std.text}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.language.num}</p>
            <p class="marginalia">{p.language.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.language.title}</h2>
            <p class="section__paragraph">{p.language.paragraph_1}</p>
            <p class="section__paragraph" set:html={p.language.paragraph_2}></p>
            <figure class="product-section__figure product-section__figure--small">
              <Image src={languageFigure} alt={p.language.figure_alt} loading="lazy" />
            </figure>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width: 22%">{p.language.table.head_scene}</th>
                    <th style="width: 39%">{p.language.table.head_ja}</th>
                    <th>{p.language.table.head_en}</th>
                  </tr>
                </thead>
                <tbody>
                  {p.language.samples.map((s: { scene: string; ja: string; en: string }) => (
                    <tr>
                      <td class="cell-strong">{s.scene}</td>
                      <td>{s.ja}</td>
                      <td class="cell-italic">{s.en}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="section__paragraph section__paragraph--quiet">{p.language.paragraph_quiet}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.market.num}</p>
            <p class="marginalia">{p.market.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title" set:html={p.market.title}></h2>
            <p class="section__paragraph" set:html={p.market.paragraph}></p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width: 28%">{p.market.table.head_area}</th>
                    <th style="width: 30%">{p.market.table.head_titles}</th>
                    <th>{p.market.table.head_gap}</th>
                  </tr>
                </thead>
                <tbody>
                  {p.market.rows.map((row: { area: string; titles: string; gap: string }) => (
                    <tr>
                      <td class="cell-strong">{row.area}</td>
                      <td>{row.titles}</td>
                      <td>{row.gap}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="section__paragraph section__paragraph--lift" set:html={p.market.lift_text}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.continuity.num}</p>
            <p class="marginalia">{p.continuity.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.continuity.title}</h2>
            <p class="section__paragraph">{p.continuity.paragraph}</p>
            <ul class="thread-list">
              {p.continuity.items.map((item: string) => <li set:html={item}></li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.roadmap.num}</p>
            <p class="marginalia">{p.roadmap.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.roadmap.title}</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width: 22%">{p.roadmap.table.head_version}</th>
                    <th>{p.roadmap.table.head_content}</th>
                    <th style="width: 22%">{p.roadmap.table.head_time}</th>
                  </tr>
                </thead>
                <tbody>
                  {p.roadmap.rows.map((row: { version: string; content: string; time: string }) => (
                    <tr>
                      <td class="cell-strong">{row.version}</td>
                      <td>{row.content}</td>
                      <td class="cell-quiet">{row.time}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.distribution.num}</p>
            <p class="marginalia">{p.distribution.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.distribution.title}</h2>
            <ol class="stage-list">
              {p.distribution.items.map((item: { num: string; title: string; text: string }) => (
                <li>
                  <span class="stage-list__num">{item.num}</span>
                  <div>
                    <h3 class="stage-list__title">{item.title}</h3>
                    <p>{item.text}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.links.num}</p>
            <p class="marginalia">{p.links.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.links.title}</h2>
            <ul class="link-list">
              {p.links.items.map((item: { label: string; href: string; text: string; note: string; external: boolean }) => (
                <li>
                  <span class="link-list__label">{item.label}</span>
                  <span>
                    {item.external
                      ? <a href={item.href} target="_blank" rel="noopener">{item.text}</a>
                      : <a href={item.href}>{item.text}</a>}
                    {item.note && <span class="link-list__note"> {item.note}</span>}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  </article>
</Layout>
