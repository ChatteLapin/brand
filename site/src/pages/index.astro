---
import { Image } from 'astro:assets';
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import logotype from '../assets/chattelapin-logotype.png';
import businessInfo from '../../../data/business-info.yaml';
import i18n from '../../../data/i18n/ja.yaml';

// mission.bridge は yaml 辞書では dict 構造 (= talent / volt / business / brand)、
// レンダリング順序を明示するため 4 件を配列化する。 ja/en 共通仕様。
const bridgeItems = [i18n.mission.bridge.talent, i18n.mission.bridge.volt, i18n.mission.bridge.business, i18n.mission.bridge.brand];
---

<Layout
  title="ChatteLapin"
  description="シャラパン (ChatteLapin) — テクノロジーとアナログの間に、 静かな時間を置く。 ソフトウェア開発業として、 主力プロダクト『Talent』 (= 国際文化 × 経営シミュレーション × 教育の PWA ゲーム) を軸に活動する個人事業。"
>
  <!-- ==========================================================
       § 00 Hero  (= 翻訳テキストは data/i18n/ja.yaml 参照)
       ========================================================== -->
  <section id="top" class="hero">
    <div class="hero__inner col-wrap">
      <div class="hero__grid">
        <div class="hero__text">
          <p class="hero__eyebrow fade-up">
            <span class="hero__eyebrow-num">{i18n.hero.eyebrow.num}</span>
            <span class="hero__eyebrow-label">{i18n.hero.eyebrow.label}</span>
          </p>
          <h1 class="hero__title fade-up delay-1">
            <span class="hero__title-line">{i18n.hero.title.line1}</span>
            <span class="hero__title-line">{i18n.hero.title.line2}</span>
            <span class="hero__title-line hero__title-line--emphasis">{i18n.hero.title.line3}</span>
          </h1>
          <p class="hero__lede fade-up delay-3" set:html={i18n.hero.lede}></p>
          <div class="hero__meta fade-up delay-4">
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.founded_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.founded_value}</span>
            </div>
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.trade_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.trade_value}</span>
            </div>
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.domicile_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.domicile_value}</span>
            </div>
          </div>
        </div>

        <figure class="hero__figure fade-up delay-2">
          <div class="hero__figure-frame">
            <Image
              src={logotype}
              alt={i18n.hero.logo_alt}
              width={600}
              height={600}
              class="hero__figure-img"
              loading="eager"
              fetchpriority="high"
              format="webp"
              quality={82}
              widths={[280, 400, 600, 800]}
              sizes="(max-width: 879px) min(50vw, 320px), 600px"
            />
          </div>
          <figcaption class="hero__figure-caption">
            <span class="hero__figure-num">{i18n.hero.figure.num}</span>
            <span class="hero__figure-desc">{i18n.hero.figure.desc}</span>
          </figcaption>
        </figure>
      </div>

      <a href="#mission" class="hero__scroll fade-in delay-5" aria-label={i18n.hero.scroll_aria}>
        <span class="hero__scroll-label">{i18n.hero.scroll_label}</span>
        <span class="hero__scroll-line" aria-hidden="true"></span>
      </a>
    </div>
  </section>

  <!-- ==========================================================
       § 01 Mission — どの橋をかけているか  (= 翻訳テキストは data/i18n/ja.yaml)
       ========================================================== -->
  <section id="mission" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.mission.num}</p>
          <p class="marginalia">{i18n.mission.marginalia}</p>
        </aside>

        <div class="section__body">
          <h2 class="section__title">{i18n.mission.title}</h2>
          <p class="section__lede dropcap" set:html={i18n.mission.lede}></p>

          <ol class="bridge-list">
            {bridgeItems.map((item) => (
              <li class="bridge-list__item">
                <span class="bridge-list__num">{item.num}</span>
                <div class="bridge-list__body">
                  <h3 class="bridge-list__title">{item.title}</h3>
                  <p class="bridge-list__text">{item.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 02 Products
       ========================================================== -->
  <section id="products" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">§ 02</p>
          <p class="marginalia">Products</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">事業の中核</p>
          <h2 class="section__title">主力プロダクト。</h2>
          <p class="section__lede">
            外部に提供する、 事業の長期的な収益と社会的価値の軸を担うプロダクト。
          </p>

          <div class="products-primary">
            <ProductCard
              name="Talent"
              tagline="国際文化 × 経営シミュレーション × 教育 の 3 軸を統合する PWA ゲーム。 世界を旅する若き商人として、 各国の店を切り盛りしながら、 文化・言葉・経済・人との縁を、 いつの間にか身につけていく。"
              href="/products/talent"
              badge="主力"
              size="large"
              number="01"
              variant="primary"
            />
          </div>

          <div class="products-divider" aria-hidden="true">
            <span class="products-divider__label">そして、 これを支える</span>
          </div>

          <h3 class="section__subtitle">主力を支える周辺の取り組み。</h3>
          <p class="section__lede section__lede--small">
            主力プロダクトの開発と長期運営を可能にするための、 実証実験プロジェクト・内部運営基盤・公開ブランド広報基盤。
          </p>

          <div class="products-satellite">
            <ProductCard
              name="volt"
              tagline="AI 活用 コミュニティ運営の実証実験。 talent の B2B 教育機関向け機能 (= 教室モード / コミュニティ運営) の前段技術検証を兼ねます。"
              href="/products/volt"
              badge="実験"
              size="medium"
              number="02"
            />
            <ProductCard
              name="business"
              tagline="freee API + Claude Vision による AI 駆動 会計自動化基盤。 事業運営の実務時間を最小化し、 主力プロダクト開発に時間を集中投下するための内部仕組み。"
              href="/products/business-automation"
              badge="運営基盤"
              size="medium"
              number="03"
            />
            <ProductCard
              name="brand"
              tagline="ロゴ・ガイドライン・公式サイトのソース・将来の広報物を集約する公開ブランド・広報資産基盤。 印刷物と画面の双方で揺らがないブランド体験の source of truth。"
              href="/products/brand"
              badge="公開ブランド・広報"
              size="medium"
              number="04"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 03 About
       ========================================================== -->
  <section id="about" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">§ 03</p>
          <p class="marginalia">About</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">事業概要</p>
          <h2 class="section__title">テクノロジーで実現する、<br />静けさのある営み。</h2>

          <div class="mission-frame">
            <p class="mission-frame__label">Mission Statement</p>
            <p class="mission-frame__text">
              テクノロジーとアナログの間に、 <br />静かな時間を置く。
            </p>
            <p class="mission-frame__body">
              デジタルは便利を運んできた一方で、 ゆっくり考える時間・紙のような手触り・人と人の小さな縁を、 そっと脇に追いやってきました。 ChatteLapin の各活動は、 失われがちなアナログの価値を、 デジタルの中にもう一度置きなおす試みです。
            </p>
            <p class="mission-frame__body">
              単に古き良きを保存するのではなく、 <strong>テクノロジーで運営しなければ実現できない静けさ</strong> を、 設計の段階から組み込みます。 すべての活動 — 主力プロダクトの開発も、 それを支える事業基盤の整備も — がこの基準のうえに立ちます。
            </p>
          </div>

          <h3 class="section__subtitle">事業の概要。</h3>
          <p class="section__paragraph">
            ChatteLapin の業種は <strong>ソフトウェア開発業</strong> です。 ソフトウェアという一つの道具で、 <strong>文化・教育・コミュニティ運営</strong> の領域に静かな時間を置く — それが事業の中核です。
          </p>
          <p class="section__paragraph">
            主力は新規ゲーム事業『<a href="/products/talent">Talent</a>』 (= 国際文化 × 経営シミュレーション × 教育の PWA ゲーム)。 これを軸として、 周辺の活動 (= AI 活用コミュニティ運営の実証実験、 事業運営を支える AI 駆動 会計自動化基盤、 ブランド・広報資産を一元化する公開基盤) を内製で並行展開しています。
          </p>
          <p class="section__paragraph section__paragraph--quiet">
            いずれも独立した「製品ライン」 ではなく、 ひとつのミッションから派生した手段の集合として位置づけています。
          </p>

          <h3 class="section__subtitle">前史 — 音楽劇団シャラパンからの継承。</h3>
          <p class="section__paragraph">
            事業者は過去に「音楽劇団シャラパン」 を立ち上げ、 主宰として「空想音楽劇 真昼の銀河」 等の公演を行ってきました。 当時の主宰メッセージには以下の理念が掲げられていました:
          </p>

          <blockquote class="legacy-quote">
            <p class="legacy-quote__text">
              経済的なゆとりだけでなく、 精神的なゆとりまでもが社会から失われがちな時代に — 観る人の心にゆとりが生まれ、 自身と隣の人々の心の豊かさを取り戻すこと。 質と量の高いステージを提供して社会に貢献すること。
            </p>
            <footer class="legacy-quote__attribution">
              <span class="legacy-quote__divider" aria-hidden="true"></span>
              <span>音楽劇団シャラパン 主宰</span>
            </footer>
          </blockquote>

          <p class="section__paragraph">
            音楽劇団シャラパンの理念は、 メディアを変えて現在も継承しています。 演劇というアナログメディアで実現してきた <strong>「心のゆとり」</strong> を、 デジタル時代の手法 (= ゲーム / AI / コミュニティ運営) で再実装する — それが現在の ChatteLapin の活動です。 『シャラパン』 の名を継続しているのも、 この理念の連続性を象徴しています。
          </p>

          <h3 class="section__subtitle">事業者プロフィール。</h3>
          <p class="section__paragraph">
            1984 年 (= 昭和 59 年) 生まれ。 就職氷河期末期に社会に出て、 続く <strong>ゆとり世代</strong> を一歩前から見つめてきた世代です。 世間で「悪名」 のように扱われた『ゆとり』 という言葉の用法とは別に、 <strong>本当の意味でのゆとり</strong> — 経済の余裕だけでなく、 時間と精神の余白 — を意識し続けてきました。 ChatteLapin のミッション「テクノロジーとアナログの間に、 静かな時間を置く」 は、 個人的な実感とも地続きの取り組みです。
          </p>

          <ul class="bio-list">
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>米国アリゾナ大学 Eller 経営学部卒業 (= 情報システム経営学・起業学・国際経営学 三重専攻)</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>過去に Web ベンチャーを設立</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>音楽劇団シャラパン主宰として「空想音楽劇 真昼の銀河」 等の舞台公演を企画・制作</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>並行して芸能・舞台・モデル業の活動経験 (= ダンス / 2.5 次元舞台プロデュース 等)</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>現職: 東京を拠点とする FA 機器メーカーで IT エンジニア・経営企画 (= 正社員、 副業公認)</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>2026-05-19 シャラパン (ChatteLapin) を個人事業として開業</span>
            </li>
          </ul>

          <p class="section__paragraph section__paragraph--lift">
            <strong>国際経営学の学術背景</strong>・ <strong>20 年超の IT エンジニアと経営企画の実装力</strong>・ <strong>音楽劇団主宰として培った文化事業の現場経験</strong> — この 3 つが交差する立場から、 単なる技術プロダクトではなく <strong>文化・教育・経営の交差点に位置する作品</strong> を生み出すことを事業の中核に据えています。
          </p>

          <h3 class="section__subtitle">基本情報。</h3>
          <dl class="info-grid">
            <div class="info-grid__row">
              <dt>事業者名</dt>
              <dd>{businessInfo.brand_display.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>開業日</dt>
              <dd>{businessInfo.founded_date}</dd>
            </div>
            <div class="info-grid__row">
              <dt>事業形態</dt>
              <dd>{businessInfo.business_form.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>業種</dt>
              <dd>{businessInfo.industry.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>管轄税務署</dt>
              <dd>{businessInfo.tax.office.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>GitHub Org</dt>
              <dd><a href={businessInfo.github.url} target="_blank" rel="noopener">{businessInfo.github.url.replace('https://', '')}</a></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 04 Contact
       ========================================================== -->
  <section id="contact" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">§ 04</p>
          <p class="marginalia">Contact</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">お問合せ</p>
          <h2 class="section__title">声をかけてください。</h2>
          <p class="section__lede">
            業務関連のご連絡は <strong>GitHub Issues</strong> でお受けしています。 下のボタンから Issue 作成画面が直接開きます (= 入力には GitHub アカウントが必要です。 無料、 数分で作成可能)。
          </p>

          <div class="contact-cta">
            <a
              href="https://github.com/ChatteLapin/brand/issues/new"
              target="_blank"
              rel="noopener"
              class="btn btn--arrow"
            >
              GitHub Issues でお問合せ
            </a>
            <p class="contact-cta__hint">
              新規タブで GitHub.com の Issue 作成画面が開きます
            </p>
          </div>

          <p class="section__paragraph section__paragraph--quiet">
            お問合せは <a href="https://github.com/ChatteLapin/brand" target="_blank" rel="noopener">brand</a> repo (= 本サイトのソースとブランド・広報資産を集約する公開 repo) の Issues でお受けします。 ご用件に関わらずお受けし、 適切な担当領域へ振り分けます。 メールフォームは順次整備します。
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
   * Hero
   * ============================================================ */

  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(4rem, 10vw, 7rem);
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -10%;
    left: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(154, 165, 112, 0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: -10%;
    right: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(circle, rgba(201, 149, 155, 0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 880px) {
    .hero__grid {
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: center;
    }
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }

  .hero__eyebrow-num {
    color: var(--color-olive-deep);
  }

  .hero__eyebrow::before {
    content: "";
    width: 2rem;
    height: 1px;
    background-color: var(--color-olive);
  }

  .hero__title {
    font-family: var(--font-serif-jp);
    font-size: clamp(2rem, 5.5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.32;
    letter-spacing: 0.06em;
    color: var(--color-ink-deep);
    margin: 0;
  }

  .hero__title-line {
    display: block;
    word-break: keep-all;
    overflow-wrap: normal;
    white-space: nowrap;
  }

  .hero__title-line--emphasis {
    color: var(--color-olive-deep);
  }

  .hero__lede {
    margin: 2rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.9;
    color: var(--color-ink-soft);
    letter-spacing: 0.025em;
    max-width: 52ch;
  }

  .hero__meta {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-paper-fold);
    max-width: 32rem;
  }

  .hero__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hero__meta-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    font-weight: 500;
  }

  .hero__meta-value {
    font-family: var(--font-serif-jp);
    font-size: 0.875rem;
    color: var(--color-ink-deep);
    letter-spacing: 0.08em;
  }

  .hero__figure {
    margin: 0 auto;
    position: relative;
    order: -1;
    width: 100%;
    max-width: clamp(200px, 50vw, 320px);
  }

  @media (min-width: 880px) {
    .hero__figure {
      order: 0;
      margin: 0;
      max-width: none;
    }
  }

  .hero__figure-frame {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: var(--color-paper-warm);
    border: 1px solid var(--color-paper-fold);
    padding: 0.75rem;
    box-shadow:
      0 1px 0 var(--color-paper-warm),
      0 12px 32px -8px rgba(58, 44, 31, 0.18),
      0 24px 48px -16px rgba(58, 44, 31, 0.12);
  }

  .hero__figure-frame::before {
    content: "";
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.75rem;
    border: 1px solid var(--color-paper-fold);
    pointer-events: none;
    z-index: 1;
  }

  .hero__figure-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 0;
  }

  .hero__figure-caption {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0 0.125rem;
  }

  @media (min-width: 880px) {
    .hero__figure-caption {
      margin-top: 1rem;
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding: 0 0.25rem;
