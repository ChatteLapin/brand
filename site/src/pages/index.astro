---
import { Image } from 'astro:assets';
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import logotype from '../assets/chattelapin-logotype.png';
import businessInfo from '../../../data/business-info.yaml';
import i18n from '../../../data/i18n/ja.yaml';

// mission.bridge は yaml 辞書では dict 構造 (= talent / volt / business / brand)、
// レンダリング順序を明示するため 4 件を配列化する。 ja/en 共通仕様。
const bridgeItems = [i18n.mission.bridge.talent, i18n.mission.bridge.volt, i18n.mission.bridge.business, i18n.mission.bridge.brand];
---

<Layout
  title="ChatteLapin"
  description="シャラパン (ChatteLapin) — テクノロジーとアナログの間に、 静かな時間を置く。 ソフトウェア開発業として、 主力プロダクト『Talent』 (= 国際文化 × 経営シミュレーション × 教育の PWA ゲーム) を軸に活動する個人事業。"
>
  <!-- ==========================================================
       § 00 Hero  (= 翻訳テキストは data/i18n/ja.yaml 参照)
       ========================================================== -->
  <section id="top" class="hero">
    <div class="hero__inner col-wrap">
      <div class="hero__grid">
        <div class="hero__text">
          <p class="hero__eyebrow fade-up">
            <span class="hero__eyebrow-num">{i18n.hero.eyebrow.num}</span>
            <span class="hero__eyebrow-label">{i18n.hero.eyebrow.label}</span>
          </p>
          <h1 class="hero__title fade-up delay-1">
            <span class="hero__title-line">{i18n.hero.title.line1}</span>
            <span class="hero__title-line">{i18n.hero.title.line2}</span>
            <span class="hero__title-line hero__title-line--emphasis">{i18n.hero.title.line3}</span>
          </h1>
          <p class="hero__lede fade-up delay-3" set:html={i18n.hero.lede}></p>
          <div class="hero__meta fade-up delay-4">
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.founded_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.founded_value}</span>
            </div>
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.trade_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.trade_value}</span>
            </div>
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.domicile_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.domicile_value}</span>
            </div>
          </div>
        </div>

        <figure class="hero__figure fade-up delay-2">
          <div class="hero__figure-frame">
            <Image
              src={logotype}
              alt={i18n.hero.logo_alt}
              width={600}
              height={600}
              class="hero__figure-img"
              loading="eager"
              fetchpriority="high"
              format="webp"
              quality={82}
              widths={[280, 400, 600, 800]}
              sizes="(max-width: 879px) min(50vw, 320px), 600px"
            />
          </div>
          <figcaption class="hero__figure-caption">
            <span class="hero__figure-num">{i18n.hero.figure.num}</span>
            <span class="hero__figure-desc">{i18n.hero.figure.desc}</span>
          </figcaption>
        </figure>
      </div>

      <a href="#mission" class="hero__scroll fade-in delay-5" aria-label={i18n.hero.scroll_aria}>
        <span class="hero__scroll-label">{i18n.hero.scroll_label}</span>
        <span class="hero__scroll-line" aria-hidden="true"></span>
      </a>
    </div>
  </section>

  <!-- ==========================================================
       § 01 Mission — どの橋をかけているか  (= 翻訳テキストは data/i18n/ja.yaml)
       ========================================================== -->
  <section id="mission" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.mission.num}</p>
          <p class="marginalia">{i18n.mission.marginalia}</p>
        </aside>

        <div class="section__body">
          <h2 class="section__title">{i18n.mission.title}</h2>
          <p class="section__lede dropcap" set:html={i18n.mission.lede}></p>

          <ol class="bridge-list">
            {bridgeItems.map((item) => (
              <li class="bridge-list__item">
                <span class="bridge-list__num">{item.num}</span>
                <div class="bridge-list__body">
                  <h3 class="bridge-list__title">{item.title}</h3>
                  <p class="bridge-list__text">{item.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 02 Products
       ========================================================== -->
  <section id="products" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.products.num}</p>
          <p class="marginalia">{i18n.products.marginalia}</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">{i18n.products.eyebrow}</p>
          <h2 class="section__title">{i18n.products.title}</h2>
          <p class="section__lede">{i18n.products.lede}</p>

          <div class="products-primary">
            <ProductCard
              name={i18n.products.cards.talent.name}
              tagline={i18n.products.cards.talent.tagline}
              href="/products/talent"
              badge={i18n.products.cards.talent.badge}
              size="large"
              number="01"
              variant="primary"
            />
          </div>

          <div class="products-divider" aria-hidden="true">
            <span class="products-divider__label">{i18n.products.divider_label}</span>
          </div>

          <h3 class="section__subtitle">{i18n.products.subtitle}</h3>
          <p class="section__lede section__lede--small">{i18n.products.satellite_lede}</p>

          <div class="products-satellite">
            <ProductCard
              name={i18n.products.cards.volt.name}
              tagline={i18n.products.cards.volt.tagline}
              href="/products/volt"
              badge={i18n.products.cards.volt.badge}
              size="medium"
              number="02"
            />
            <ProductCard
              name={i18n.products.cards.business.name}
              tagline={i18n.products.cards.business.tagline}
              href="/products/business-automation"
              badge={i18n.products.cards.business.badge}
              size="medium"
              number="03"
            />
            <ProductCard
              name={i18n.products.cards.brand.name}
              tagline={i18n.products.cards.brand.tagline}
              href="/products/brand"
              badge={i18n.products.cards.brand.badge}
              size="medium"
              number="04"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 03 About
       ========================================================== -->
  <section id="about" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.about.num}</p>
          <p class="marginalia">{i18n.about.marginalia}</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">{i18n.about.eyebrow}</p>
          <h2 class="section__title" set:html={i18n.about.title}></h2>

          <div class="mission-frame">
            <p class="mission-frame__label">{i18n.about.mission_frame.label}</p>
            <p class="mission-frame__text" set:html={i18n.about.mission_frame.text}></p>
            <p class="mission-frame__body" set:html={i18n.about.mission_frame.body_1}></p>
            <p class="mission-frame__body" set:html={i18n.about.mission_frame.body_2}></p>
          </div>

          <h3 class="section__subtitle">{i18n.about.overview.subtitle}</h3>
          <p class="section__paragraph" set:html={i18n.about.overview.paragraph_1}></p>
          <p class="section__paragraph" set:html={i18n.about.overview.paragraph_2}></p>
          <p class="section__paragraph section__paragraph--quiet" set:html={i18n.about.overview.paragraph_3}></p>

          <h3 class="section__subtitle">{i18n.about.legacy.subtitle}</h3>
          <p class="section__paragraph" set:html={i18n.about.legacy.intro}></p>

          <blockquote class="legacy-quote">
            <p class="legacy-quote__text">{i18n.about.legacy.quote_text}</p>
            <footer class="legacy-quote__attribution">
              <span class="legacy-quote__divider" aria-hidden="true"></span>
              <span>{i18n.about.legacy.quote_attribution}</span>
            </footer>
          </blockquote>

          <p class="section__paragraph" set:html={i18n.about.legacy.inheritance}></p>

          <h3 class="section__subtitle">{i18n.about.profile.subtitle}</h3>
          <p class="section__paragraph" set:html={i18n.about.profile.intro}></p>

          <ul class="bio-list">
            {i18n.about.profile.bio.map((item: string) => (
              <li class="bio-list__item">
                <span class="bio-list__bullet" aria-hidden="true"></span>
                <span set:html={item}></span>
              </li>
            ))}
          </ul>

          <p class="section__paragraph section__paragraph--lift" set:html={i18n.about.profile.lift}></p>

          <h3 class="section__subtitle">{i18n.about.info.subtitle}</h3>
          <dl class="info-grid">
            <div class="info-grid__row">
              <dt>{i18n.about.info.labels.name}</dt>
              <dd>{businessInfo.brand_display.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>{i18n.about.info.labels.founded}</dt>
              <dd>{businessInfo.founded_date}</dd>
            </div>
            <div class="info-grid__row">
              <dt>{i18n.about.info.labels.form}</dt>
              <dd>{businessInfo.business_form.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>{i18n.about.info.labels.industry}</dt>
              <dd>{businessInfo.industry.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>{i18n.about.info.labels.tax_office}</dt>
              <dd>{businessInfo.tax.office.ja}</dd>
            </div>
            <div class="info-grid__row">
              <dt>{i18n.about.info.labels.github_org}</dt>
              <dd><a href={businessInfo.github.url} target="_blank" rel="noopener">{businessInfo.github.url.replace('https://', '')}</a></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 04 Contact
       ========================================================== -->
  <section id="contact" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.contact.num}</p>
          <p class="marginalia">{i18n.contact.marginalia}</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">{i18n.contact.eyebrow}</p>
          <h2 class="section__title">{i18n.contact.title}</h2>
          <p class="section__lede" set:html={i18n.contact.lede}></p>

          <div class="contact-cta">
            <a
              href="https://github.com/ChatteLapin/brand/issues/new"
              target="_blank"
              rel="noopener"
              class="btn btn--arrow"
            >
              {i18n.contact.cta.label}
            </a>
            <p class="contact-cta__hint">{i18n.contact.cta.hint}</p>
          </div>

          <p class="section__paragraph section__paragraph--quiet" set:html={i18n.contact.fallback}></p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
   * Hero
   * ============================================================ */

  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(4rem, 10vw, 7rem);
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -10%;
    left: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(154, 165, 112, 0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: -10%;
    right: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(circle, rgba(201, 149, 155, 0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 880px) {
    .hero__grid {
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: center;
    }
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }

  .hero__eyebrow-num {
    color: var(--color-olive-deep);
  }

  .hero__eyebrow::before {
    content: "";
    width: 2rem;
    height: 1px;
    background-color: var(--color-olive);
  }

  .hero__title {
    font-family: var(--font-serif-jp);
    font-size: clamp(2rem, 5.5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.32;
    letter-spacing: 0.06em;
    color: var(--color-ink-deep);
    margin: 0;
  }

  .hero__title-line {
    display: block;
    word-break: keep-all;
    overflow-wrap: normal;
    white-space: nowrap;
  }

  .hero__title-line--emphasis {
    color: var(--color-olive-deep);
  }

  .hero__lede {
    margin: 2rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.9;
    color: var(--color-ink-soft);
    letter-spacing: 0.025em;
    max-width: 52ch;
  }

  .hero__meta {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-paper-fold);
    max-width: 32rem;
  }

  .hero__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hero__meta-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    font-weight: 500;
  }

  .hero__meta-value {
    font-family: var(--font-serif-jp);
    font-size: 0.875rem;
    color: var(--color-ink-deep);
    letter-spacing: 0.08em;
  }

  .hero__figure {
    margin: 0 auto;
    position: relative;
    order: -1;
    width: 100%;
    max-width: clamp(200px, 50vw, 320px);
  }

  @media (min-width: 880px) {
    .hero__figure {
      order: 0;
      margin: 0;
      max-width: none;
    }
  }

  .hero__figure-frame {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: var(--color-paper-warm);
    border: 1px solid var(--color-paper-fold);
    padding: 0.75rem;
    box-shadow:
      0 1px 0 var(--color-paper-warm),
      0 12px 32px -8px rgba(58, 44, 31, 0.18),
      0 24px 48px -16px rgba(58, 44, 31, 0.12);
  }

  .hero__figure-frame::before {
    content: "";
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.75rem;
    border: 1px solid var(--color-paper-fold);
    pointer-events: none;
    z-index: 1;
  }

  .hero__figure-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 0;
  }

  .hero__figure-caption {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0 0.125rem;
  }

  @media (min-width: 880px) {
    .hero__figure-caption {
      margin-top: 1rem;
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding: 0 0.25rem;
    }
  }

  .hero__figure-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--color-olive);
    text-transform: uppercase;
    font-weight: 500;
  }

  .hero__figure-desc {
    font-family: var(--font-serif-jp);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .hero__scroll {
    display: none;
    margin-top: 4rem;
    text-decoration: none;
    color: var(--color-ink-faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    align-items: center;
    gap: 1rem;
    width: fit-content;
  }

  @media (min-width: 880px) {
    .hero__scroll {
      display: inline-flex;
    }
  }

  .hero__scroll-line {
    width: 4rem;
    height: 1px;
    background: linear-gradient(to right, var(--color-ink-faint), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: -30%;
    width: 30%;
    height: 100%;
    background-color: var(--color-olive-deep);
    animation: scrollDot 2.5s ease-in-out infinite;
  }

  @keyframes scrollDot {
    0% { left: -30%; }
    60% { left: 100%; }
    100% { left: 100%; }
  }

  .hero__scroll:hover {
    color: var(--color-ink-deep);
    text-decoration: none;
  }

  /* ============================================================
   * Section base
   * ============================================================ */

  .section {
    padding: clamp(3.5rem, 8vw, 6rem) 0;
    position: relative;
  }

  .section__aside {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 0.5rem;
  }

  @media (min-width: 960px) {
    .section__aside {
      position: sticky;
      top: 6rem;
      align-self: flex-start;
      padding-top: 1rem;
    }
  }

  .section__body {
    min-width: 0;
  }

  .section__title {
    font-family: var(--font-serif-jp);
    font-size: clamp(1.875rem, 4.5vw, 2.75rem);
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1.32;
    color: var(--color-ink-deep);
    margin: 0.5rem 0 1.5rem;
  }

  .section__subtitle {
    font-family: var(--font-serif-jp);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1.45;
    color: var(--color-ink-deep);
    margin: 4rem 0 1.25rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-paper-fold);
    position: relative;
  }

  .section__subtitle::before {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 4rem;
    height: 1px;
    background-color: var(--color-olive);
  }

  .section__lede {
    font-family: var(--font-sans-jp);
    font-size: 1rem;
    line-height: 1.95;
    color: var(--color-ink-soft);
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  .section__lede--small {
    font-size: 0.9375rem;
  }

  .section__paragraph {
    font-family: var(--font-sans-jp);
    font-size: 0.9375rem;
    line-height: 1.95;
    color: var(--color-ink-deep);
    margin: 0 0 1.25rem;
    max-width: 62ch;
  }

  .section__paragraph--quiet {
    color: var(--color-ink-soft);
    font-size: 0.875rem;
  }

  .section__paragraph--lift {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-paper-fold);
    color: var(--color-ink-soft);
  }

  /* ============================================================
   * Mission — bridge-list
   * ============================================================ */

  .bridge-list {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    counter-reset: bridge;
  }

  .bridge-list__item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-paper-fold);
    align-items: baseline;
  }

  .bridge-list__num {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.16em;
    color: var(--color-olive);
    font-weight: 500;
  }

  .bridge-list__title {
    font-family: var(--font-serif-jp);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-ink-deep);
    margin: 0;
  }

  .bridge-list__text {
    font-family: var(--font-sans-jp);
    font-size: 0.9375rem;
    line-height: 1.85;
    color: var(--color-ink-soft);
    margin: 0.5rem 0 0;
  }

  /* ============================================================
   * Products
   * ============================================================ */

  .products-primary {
    margin: 2.5rem 0 0;
  }

  .products-divider {
    margin: 4rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    max-width: 28rem;
    color: var(--color-ink-faint);
  }

  .products-divider::before,
  .products-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background-color: var(--color-paper-fold);
  }

  .products-divider__label {
    font-family: var(--font-serif-jp);
    font-style: italic;
    font-size: 0.875rem;
    letter-spacing: 0.12em;
    color: var(--color-ink-faint);
  }

  .products-satellite {
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 720px) {
