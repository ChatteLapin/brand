---
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import logotype from '../../assets/chattelapin-logotype.png';
import businessInfo from '../../../../data/business-info.yaml';
import i18n from '../../../../data/i18n/en.yaml';

// mission.bridge は yaml 辞書では dict 構造、 レンダリング順序を明示するため 4 件を配列化。 ja と同仕様。
const bridgeItems = [i18n.mission.bridge.talent, i18n.mission.bridge.volt, i18n.mission.bridge.business, i18n.mission.bridge.brand];
---

<Layout
  title="ChatteLapin"
  description="ChatteLapin (Japanese: シャラパン) — A pause of quiet between technology and the analog. A sole proprietorship operating Talent, a PWA game weaving global cultures, business simulation, and education."
  locale="en"
>
  <!-- ==========================================================
       § 00 Hero  (= text from data/i18n/en.yaml)
       ========================================================== -->
  <section id="top" class="hero">
    <div class="hero__inner col-wrap">
      <div class="hero__grid">
        <div class="hero__text">
          <p class="hero__eyebrow fade-up">
            <span class="hero__eyebrow-num">{i18n.hero.eyebrow.num}</span>
            <span class="hero__eyebrow-label">{i18n.hero.eyebrow.label}</span>
          </p>
          <h1 class="hero__title fade-up delay-1">
            <span class="hero__title-line">{i18n.hero.title.line1}</span>
            <span class="hero__title-line">{i18n.hero.title.line2}</span>
            <span class="hero__title-line hero__title-line--emphasis">{i18n.hero.title.line3}</span>
          </h1>
          <p class="hero__lede fade-up delay-3" set:html={i18n.hero.lede}></p>
          <div class="hero__meta fade-up delay-4">
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.founded_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.founded_value}</span>
            </div>
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.trade_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.trade_value}</span>
            </div>
            <div class="hero__meta-item">
              <span class="hero__meta-label">{i18n.hero.meta.domicile_label}</span>
              <span class="hero__meta-value">{i18n.hero.meta.domicile_value}</span>
            </div>
          </div>
        </div>

        <figure class="hero__figure fade-up delay-2">
          <div class="hero__figure-frame">
            <Image
              src={logotype}
              alt={i18n.hero.logo_alt}
              width={600}
              height={600}
              class="hero__figure-img"
              loading="eager"
              fetchpriority="high"
              format="webp"
              quality={82}
              widths={[280, 400, 600, 800]}
              sizes="(max-width: 879px) min(50vw, 320px), 600px"
            />
          </div>
          <figcaption class="hero__figure-caption">
            <span class="hero__figure-num">{i18n.hero.figure.num}</span>
            <span class="hero__figure-desc">{i18n.hero.figure.desc}</span>
          </figcaption>
        </figure>
      </div>

      <a href="#mission" class="hero__scroll fade-in delay-5" aria-label={i18n.hero.scroll_aria}>
        <span class="hero__scroll-label">{i18n.hero.scroll_label}</span>
        <span class="hero__scroll-line" aria-hidden="true"></span>
      </a>
    </div>
  </section>

  <!-- ==========================================================
       § 01 Mission  (= text from data/i18n/en.yaml)
       ========================================================== -->
  <section id="mission" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.mission.num}</p>
          <p class="marginalia">{i18n.mission.marginalia}</p>
        </aside>

        <div class="section__body">
          <h2 class="section__title">{i18n.mission.title}</h2>
          <p class="section__lede dropcap" set:html={i18n.mission.lede}></p>

          <ol class="bridge-list">
            {bridgeItems.map((item) => (
              <li class="bridge-list__item">
                <span class="bridge-list__num">{item.num}</span>
                <div class="bridge-list__body">
                  <h3 class="bridge-list__title">{item.title}</h3>
                  <p class="bridge-list__text">{item.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 02 Products
       ========================================================== -->
  <section id="products" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">§ 02</p>
          <p class="marginalia">Products</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">Core of the business</p>
          <h2 class="section__title">Flagship product.</h2>
          <p class="section__lede">
            The product offered to the outside world, carrying the long-term revenue and social value of the business.
          </p>

          <div class="products-primary">
            <ProductCard
              name="Talent"
              tagline="A PWA game weaving three axes — global cultures × business simulation × education. As a young merchant traveling the world, run shops in many countries, and along the way, take in cultures, languages, economies, and quiet bonds with people."
              href="/products/talent"
              badge="Flagship"
              size="large"
              number="01"
              variant="primary"
            />
          </div>

          <div class="products-divider" aria-hidden="true">
            <span class="products-divider__label">and supporting it</span>
          </div>

          <h3 class="section__subtitle">Surrounding work that supports the flagship.</h3>
          <p class="section__lede section__lede--small">
            Proof-of-concept projects, internal operating infrastructure, and a public brand foundation — together they make the development and long-term operation of the flagship possible.
          </p>

          <div class="products-satellite">
            <ProductCard
              name="volt"
              tagline="A proof-of-concept project for AI-assisted community operations. Also a technical precursor to Talent's B2B school features (= classroom mode / community operation)."
              href="/products/volt"
              badge="Experiment"
              size="medium"
              number="02"
            />
            <ProductCard
              name="business"
              tagline="An AI-driven accounting automation platform built on the freee API and Claude Vision. An internal mechanism designed to minimize the operational hours of running a business, so that time can be concentrated on the flagship."
              href="/products/business-automation"
              badge="Operating base"
              size="medium"
              number="03"
            />
            <ProductCard
              name="brand"
              tagline="A public brand and communications foundation that consolidates the logo, guidelines, official site source, and future printed materials. The source of truth for a brand experience that does not waver between print and screen."
              href="/products/brand"
              badge="Public brand"
              size="medium"
              number="04"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 03 About
       ========================================================== -->
  <section id="about" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">§ 03</p>
          <p class="marginalia">About</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">About</p>
          <h2 class="section__title">A quiet practice,<br />made possible by technology.</h2>

          <div class="mission-frame">
            <p class="mission-frame__label">Mission Statement</p>
            <p class="mission-frame__text">
              Place a quiet hour <br />between technology and the analog.
            </p>
            <p class="mission-frame__body">
              The digital has brought convenience; at the same time, it has quietly pushed aside the time to think at one's own pace, the texture of paper, and the small ties between people. Each activity of ChatteLapin is an attempt to set the receding analog values back, within the digital.
            </p>
            <p class="mission-frame__body">
              Not a mere preservation of the old; rather, <strong>a quietness that can only be operated through technology</strong> is built in from the design stage. All activities — both the development of the flagship and the operating bases that support it — stand on this principle.
            </p>
          </div>

          <h3 class="section__subtitle">Business overview.</h3>
          <p class="section__paragraph">
            ChatteLapin's industry is <strong>Software Development</strong>. With a single tool — software — we place quiet time within the realms of <strong>culture, education, and community operations</strong>. This is the core of the business.
          </p>
          <p class="section__paragraph">
            The flagship is the new game project <strong>Talent</strong> (a PWA game weaving global cultures × business simulation × education). Around this core, we run in parallel — in-house — the surrounding activities: a proof-of-concept project for AI-assisted community operations, an AI-driven accounting automation platform that supports our operations, and a public foundation consolidating brand and communications assets.
          </p>
          <p class="section__paragraph section__paragraph--quiet">
            None of these are independent "product lines"; they are a set of means derived from a single mission.
          </p>

          <h3 class="section__subtitle">Prelude — inherited from the ChatteLapin musical theatre.</h3>
          <p class="section__paragraph">
            The proprietor previously founded a musical theatre company, <em>音楽劇団シャラパン</em> ("ChatteLapin Musical Theatre" in English), and produced stage works including <em>Daydream Musical: Midday Galaxy</em>. The mission statement of that time read as follows:
          </p>

          <blockquote class="legacy-quote">
            <p class="legacy-quote__text">
              In an age when society loses not only economic ease but also the ease of the heart — that the audience may find a quietness of the heart born within them, and that they and the people beside them may recover an inner richness. To contribute to society through high-quality, high-volume stage works.
            </p>
            <footer class="legacy-quote__attribution">
              <span class="legacy-quote__divider" aria-hidden="true"></span>
              <span>Director, 音楽劇団シャラパン (ChatteLapin Musical Theatre)</span>
            </footer>
          </blockquote>

          <p class="section__paragraph">
            The principle of the ChatteLapin musical theatre has changed its medium, and continues today. The <strong>"inner ease"</strong> once realized through the analog medium of theatre is now reimplemented through digital means — games, AI, community operations. This is the present work of ChatteLapin. Continuing the name <em>シャラパン (ChatteLapin)</em> is a token of this continuity.
          </p>

          <h3 class="section__subtitle">About the proprietor.</h3>
          <p class="section__paragraph">
            Born in 1984 (Shōwa 59). Entered the workforce at the tail end of Japan's Employment Ice Age, and watched the subsequent "yutori generation" from a step ahead. Apart from the popular pejorative usage of the word <em>yutori</em>, the proprietor has long held in mind a different sense — <strong>genuine ease</strong>, meaning not only financial comfort but the margin of time and spirit. The ChatteLapin mission, "Place a quiet hour between technology and the analog," is continuous with that personal conviction.
          </p>

          <ul class="bio-list">
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>BBA, Eller College of Management, University of Arizona — triple major in Management Information Systems, Entrepreneurship, and International Management</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>Previously founded a web venture</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>Director of 音楽劇団シャラパン (ChatteLapin Musical Theatre), producing stage works including <em>Daydream Musical: Midday Galaxy</em></span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>Parallel experience in performing arts and modeling (dance, 2.5D stage production, etc.)</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>Day job: IT engineer / business planning at a Tokyo-based factory automation manufacturer (full-time, with side-work permitted)</span>
            </li>
            <li class="bio-list__item">
              <span class="bio-list__bullet" aria-hidden="true"></span>
              <span>2026-05-19, opened ChatteLapin (Japanese: シャラパン) as a sole proprietorship</span>
            </li>
          </ul>

          <p class="section__paragraph section__paragraph--lift">
            <strong>An academic grounding in International Management</strong>, <strong>over 20 years of practice as an IT engineer and business planner</strong>, and <strong>field experience in cultural enterprise as director of a musical theatre company</strong> — from the intersection of these three, the business places at its core not mere technical products but <strong>works at the crossroads of culture, education, and management</strong>.
          </p>

          <h3 class="section__subtitle">Basic information.</h3>
          <dl class="info-grid">
            <div class="info-grid__row">
              <dt>Name</dt>
              <dd>{businessInfo.brand_display.en}</dd>
            </div>
            <div class="info-grid__row">
              <dt>Founded</dt>
              <dd>{businessInfo.founded_date}</dd>
            </div>
            <div class="info-grid__row">
              <dt>Form</dt>
              <dd>{businessInfo.business_form.en}</dd>
            </div>
            <div class="info-grid__row">
              <dt>Industry</dt>
              <dd>{businessInfo.industry.en}</dd>
            </div>
            <div class="info-grid__row">
              <dt>Tax office</dt>
              <dd>{businessInfo.tax.office.en}</dd>
            </div>
            <div class="info-grid__row">
              <dt>GitHub Org</dt>
              <dd><a href={businessInfo.github.url} target="_blank" rel="noopener">{businessInfo.github.url.replace('https://', '')}</a></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <div class="ornament-rule" aria-hidden="true"><span class="ornament-rule__glyph">❦   ❦   ❦</span></div>

  <!-- ==========================================================
       § 04 Contact
       ========================================================== -->
  <section id="contact" class="section reveal">
    <div class="col-wrap">
      <div class="editorial-grid">
        <aside class="section__aside">
          <p class="section-num">{i18n.contact.num}</p>
          <p class="marginalia">{i18n.contact.marginalia}</p>
        </aside>

        <div class="section__body">
          <p class="eyebrow">{i18n.contact.eyebrow}</p>
          <h2 class="section__title">{i18n.contact.title}</h2>
          <p class="section__lede" set:html={i18n.contact.lede}></p>

          <div class="contact-cta">
            <a
              href="https://github.com/ChatteLapin/brand/issues/new"
              target="_blank"
              rel="noopener"
              class="btn btn--arrow"
            >
              {i18n.contact.cta.label}
            </a>
            <p class="contact-cta__hint">{i18n.contact.cta.hint}</p>
          </div>

          <p class="section__paragraph section__paragraph--quiet" set:html={i18n.contact.fallback}></p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
   * Hero
   * ============================================================ */

  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(4rem, 10vw, 7rem);
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -10%;
    left: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(154, 165, 112, 0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: -10%;
    right: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(circle, rgba(201, 149, 155, 0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 880px) {
    .hero__grid {
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: center;
    }
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }

  .hero__eyebrow-num {
    color: var(--color-olive-deep);
  }

  .hero__eyebrow::before {
    content: "";
    width: 2rem;
    height: 1px;
    background-color: var(--color-olive);
  }

  .hero__title {
    font-family: var(--font-serif-jp);
    font-size: clamp(2rem, 5.5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.32;
    letter-spacing: 0.06em;
    color: var(--color-ink-deep);
    margin: 0;
  }

  .hero__title-line {
    display: block;
    word-break: keep-all;
    overflow-wrap: normal;
    white-space: nowrap;
  }

  .hero__title-line--emphasis {
    color: var(--color-olive-deep);
  }

  .hero__lede {
    margin: 2rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.9;
    color: var(--color-ink-soft);
    letter-spacing: 0.025em;
    max-width: 52ch;
  }

  .hero__meta {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-paper-fold);
    max-width: 32rem;
  }

  .hero__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hero__meta-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    font-weight: 500;
  }

  .hero__meta-value {
    font-family: var(--font-serif-jp);
    font-size: 0.875rem;
    color: var(--color-ink-deep);
    letter-spacing: 0.08em;
  }

  .hero__figure {
    margin: 0 auto;
    position: relative;
    order: -1;
    width: 100%;
    max-width: clamp(200px, 50vw, 320px);
  }

  @media (min-width: 880px) {
    .hero__figure {
      order: 0;
      margin: 0;
      max-width: none;
    }
  }

  .hero__figure-frame {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: var(--color-paper-warm);
    border: 1px solid var(--color-paper-fold);
    padding: 0.75rem;
    box-shadow:
      0 1px 0 var(--color-paper-warm),
      0 12px 32px -8px rgba(58, 44, 31, 0.18),
      0 24px 48px -16px rgba(58, 44, 31, 0.12);
  }

  .hero__figure-frame::before {
    content: "";
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.75rem;
    border: 1px solid var(--color-paper-fold);
    pointer-events: none;
    z-index: 1;
  }

  .hero__figure-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 0;
  }

  .hero__figure-caption {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0 0.125rem;
  }

  @media (min-width: 880px) {
    .hero__figure-caption {
      margin-top: 1rem;
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding: 0 0.25rem;
    }
  }

  .hero__figure-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--color-olive);
    text-transform: uppercase;
    font-weight: 500;
  }

  .hero__figure-desc {
    font-family: var(--font-serif-jp);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .hero__scroll {
    display: none;
    margin-top: 4rem;
    text-decoration: none;
    color: var(--color-ink-faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    align-items: center;
    gap: 1rem;
    width: fit-content;
  }

  @media (min-width: 880px) {
    .hero__scroll {
      display: inline-flex;
    }
  }

  .hero__scroll-line {
    width: 4rem;
    height: 1px;
    background: linear-gradient(to right, var(--color-ink-faint), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: -30%;
    width: 30%;
    height: 100%;
    background-color: var(--color-olive-deep);
    animation: scrollDot 2.5s ease-in-out infinite;
  }

  @keyframes scrollDot {
    0% { left: -30%; }
    60% { left: 100%; }
    100% { left: 100%; }
  }

  .hero__scroll:hover {
    color: var(--color-ink-deep);
    text-decoration: none;
  }

  /* ============================================================
   * Section base
   * ============================================================ */

  .section {
    padding: clamp(3.5rem, 8vw, 6rem) 0;
    position: relative;
  }

  .section__aside {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 0.5rem;
  }

  @media (min-width: 960px) {
    .section__aside {
      position: sticky;
      top: 6rem;
      align-self: flex-start;
      padding-top: 1rem;
    }
  }

  .section__body {
    min-width: 0;
  }

  .section__title {
    font-family: var(--font-serif-jp);
    font-size: clamp(1.875rem, 4.5vw, 2.75rem);
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1.32;
    color: var(--color-ink-deep);
    margin: 0.5rem 0 1.5rem;
  }

  .section__subtitle {
    font-family: var(--font-serif-jp);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1.45;
    color: var(--color-ink-deep);
    margin: 4rem 0 1.25rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-paper-fold);
    position: relative;
  }

  .section__subtitle::before {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 4rem;
    height: 1px;
    background-color: var(--color-olive);
  }

  .section__lede {
    font-family: var(--font-sans-jp);
    font-size: 1rem;
    line-height: 1.95;
    color: var(--color-ink-soft);
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  .section__lede--small {
    font-size: 0.9375rem;
  }

  .section__paragraph {
    font-family: var(--font-sans-jp);
    font-size: 0.9375rem;
    line-height: 1.95;
    color: var(--color-ink-deep);
    margin: 0 0 1.25rem;
    max-width: 62ch;
  }

  .section__paragraph--quiet {
    color: var(--color-ink-soft);
    font-size: 0.875rem;
  }

  .section__paragraph--lift {
