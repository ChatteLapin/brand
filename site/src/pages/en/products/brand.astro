---
import Layout from '../../../components/Layout.astro';
import i18n from '../../../../../data/i18n/en.yaml';
import '../../../styles/products/brand.css';

const p = i18n.products_brand;
---

<Layout title={p.layout.title} description={p.layout.description} locale="en">
  <article class="product-article">
    <header class="product-header reveal">
      <div class="col-wrap">
        <p class="product-header__breadcrumb">
          <a href="/en#products">{p.breadcrumb_label}</a>
          <span aria-hidden="true">/</span>
          <span>{p.header.title}</span>
        </p>
        <p class="eyebrow product-header__eyebrow">{p.header.eyebrow}</p>
        <h1 class="product-header__title">{p.header.title}</h1>
        <p class="product-header__tagline">{p.header.tagline}</p>
        <div class="product-header__meta">
          <div><span>{p.header.meta.field_label}</span><strong>{p.header.meta.field_value}</strong></div>
          <div><span>{p.header.meta.status_label}</span><strong>{p.header.meta.status_value}</strong></div>
          <div><span>{p.header.meta.access_label}</span><strong>{p.header.meta.access_value}</strong></div>
        </div>
      </div>
    </header>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.position.num}</p>
            <p class="marginalia">{p.position.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.position.title}</h2>
            <p class="section__paragraph" set:html={p.position.paragraph_1}></p>
            <p class="section__paragraph" set:html={p.position.paragraph_2}></p>
            <p class="section__paragraph section__paragraph--quiet" set:html={p.position.paragraph_3}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.assets.num}</p>
            <p class="marginalia">{p.assets.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.assets.title}</h2>
            <ul class="asset-list">
              {p.assets.items.map((item: { title: string; text: string; future?: boolean }) => (
                <li class={item.future ? 'asset-list__item--future' : ''}>
                  <p class="asset-list__title">{item.title}</p>
                  <p class="asset-list__text" set:html={item.text}></p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.operation.num}</p>
            <p class="marginalia">{p.operation.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.operation.title}</h2>
            <p class="section__paragraph" set:html={p.operation.paragraph}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.links.num}</p>
            <p class="marginalia">{p.links.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.links.title}</h2>
            <ul class="link-list">
              {p.links.items.map((item: { label: string; href: string; text: string; note: string; external: boolean }) => (
                <li>
                  <span class="link-list__label">{item.label}</span>
                  <span>
                    {item.external
                      ? <a href={item.href} target="_blank" rel="noopener">{item.text}</a>
                      : <a href={item.href}>{item.text}</a>}
                    {item.note && <span class="link-list__note"> {item.note}</span>}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  </article>
</Layout>
