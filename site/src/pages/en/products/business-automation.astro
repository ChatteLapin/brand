---
import Layout from '../../../components/Layout.astro';
import i18n from '../../../../../data/i18n/en.yaml';

const p = i18n.products_business;
---

<Layout title={p.layout.title} description={p.layout.description} locale="en">
  <article class="product-article">
    <header class="product-header reveal">
      <div class="col-wrap">
        <p class="product-header__breadcrumb">
          <a href="/en#products">{p.breadcrumb_label}</a>
          <span aria-hidden="true">/</span>
          <span>{p.header.title}</span>
        </p>
        <p class="eyebrow product-header__eyebrow">{p.header.eyebrow}</p>
        <h1 class="product-header__title">{p.header.title}</h1>
        <p class="product-header__tagline">{p.header.tagline}</p>
        <div class="product-header__meta">
          <div><span>{p.header.meta.field_label}</span><strong>{p.header.meta.field_value}</strong></div>
          <div><span>{p.header.meta.status_label}</span><strong>{p.header.meta.status_value}</strong></div>
          <div><span>{p.header.meta.policy_label}</span><strong>{p.header.meta.policy_value}</strong></div>
        </div>
      </div>
    </header>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.position.num}</p>
            <p class="marginalia">{p.position.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.position.title}</h2>
            <p class="section__paragraph" set:html={p.position.paragraph_1}></p>
            <p class="section__paragraph" set:html={p.position.paragraph_2}></p>
            <p class="section__paragraph section__paragraph--quiet" set:html={p.position.paragraph_3}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.pipeline.num}</p>
            <p class="marginalia">{p.pipeline.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.pipeline.title}</h2>
            <ol class="layer-list">
              {p.pipeline.layers.map((layer: { num: string; title: string; text: string }) => (
                <li class="layer-list__item">
                  <span class="layer-list__num">{layer.num}</span>
                  <div class="layer-list__body">
                    <h3 class="layer-list__title">{layer.title}</h3>
                    <p class="layer-list__text">{layer.text}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.progress.num}</p>
            <p class="marginalia">{p.progress.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.progress.title}</h2>
            <p class="section__paragraph" set:html={p.progress.paragraph_1}></p>
            <p class="section__paragraph" set:html={p.progress.paragraph_2}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.stack.num}</p>
            <p class="marginalia">{p.stack.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.stack.title}</h2>
            <ul class="check-list">
              {p.stack.items.map((item: string) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="product-section reveal">
      <div class="col-wrap">
        <div class="editorial-grid">
          <aside class="section__aside">
            <p class="section-num">{p.links.num}</p>
            <p class="marginalia">{p.links.marginalia}</p>
          </aside>
          <div class="section__body">
            <h2 class="section__title">{p.links.title}</h2>
            <ul class="link-list">
              {p.links.items.map((item: { label: string; href: string; text: string; note: string; external: boolean }) => (
                <li>
                  <span class="link-list__label">{item.label}</span>
                  <span>
                    {item.external
                      ? <a href={item.href} target="_blank" rel="noopener">{item.text}</a>
                      : <a href={item.href}>{item.text}</a>}
                    {item.note && <span class="link-list__note"> {item.note}</span>}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  </article>
</Layout>

<style>
  /* page 共通 style (= product-article / product-header / product-section / section__* / link-list / check-list) は
     global.css に集約済。 本ファイルでは business 専用 layer-list (= 3 層パイプラインの箱型カード) のみ維持。 */

  .layer-list {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .layer-list__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1.25rem;
    padding: 1.5rem;
    background-color: rgba(255, 252, 245, 0.55);
    border: 1px solid var(--color-paper-fold);
    align-items: start;
    transition: border-color 200ms ease, background-color 200ms ease;
  }
  .layer-list__item:hover {
    border-color: var(--color-olive);
    background-color: rgba(255, 252, 245, 0.85);
  }
  .layer-list__num {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-olive);
    font-weight: 500;
    letter-spacing: 0.06em;
    padding-top: 0.125rem;
  }
  .layer-list__title {
    font-family: var(--font-serif-jp);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-ink-deep);
    margin: 0 0 0.625rem;
  }
  .layer-list__text {
    font-family: var(--font-sans-jp);
    font-size: 0.9375rem;
    line-height: 1.85;
    color: var(--color-ink-soft);
    margin: 0;
  }
</style>
