---
// ChatteLapin Header — 古典書物の扉ページ × シャープなナビゲーション
// 翻訳テキストは data/i18n/{ja,en}.yaml に集約。 locale は Astro.currentLocale で切替。
import { Image } from 'astro:assets';
import mark from '../assets/chattelapin-mark.png';
import talentLogo3to1 from '../assets/products/talent-logo-3to1.svg';
import talentLogo1to1 from '../assets/products/talent-logo-1to1.svg';
import jaDict from '../../../data/i18n/ja.yaml';
import enDict from '../../../data/i18n/en.yaml';

const locale = Astro.currentLocale || 'ja';
const isJa = locale === 'ja';
const i18n = isJa ? jaDict : enDict;
const homeHref = isJa ? '/' : '/en';
const talentHref = isJa ? '/products/talent' : '/en/products/talent';

// 現在 page の言語切替先 URL を算出 (= /products/talent <-> /en/products/talent 等)
// 切替ボタンを押したら現在 page を維持して言語だけ切り替わる
// Astro.url.pathname は `format: 'file'` 設定下では `.html` 拡張子付きになるので除去
const rawPath = Astro.url.pathname;
const pathname = rawPath.replace(/\.html$/, '').replace(/\/index$/, '') || '/';
const altLocalePath = isJa
  ? (pathname === '/' ? '/en' : `/en${pathname}`)
  : (pathname.replace(/^\/en/, '') || '/');

const navItems = [
  { key: 'mission', num: '01', label: i18n.header.nav.mission, href: `${homeHref}#mission` },
  { key: 'products', num: '02', label: i18n.header.nav.products, href: `${homeHref}#products` },
  { key: 'about', num: '03', label: i18n.header.nav.about, href: `${homeHref}#about` },
  { key: 'contact', num: '04', label: i18n.header.nav.contact, href: `${homeHref}#contact` },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={homeHref} class="site-header__brand" aria-label={i18n.header.brand_aria}>
      <span class="site-header__mark-wrap" aria-hidden="true">
        <Image
          src={mark}
          alt=""
          width={44}
          height={44}
          densities={[1, 2, 3]}
          format="webp"
          quality={85}
          loading="eager"
          class="site-header__mark"
        />
      </span>
      <span class="site-header__wordmark">
        <span class="site-header__name-ja">シャラパン</span>
        <span class="site-header__name-en">Chatte Lapin</span>
      </span>
    </a>

    <nav class="site-nav" aria-label={i18n.header.nav_aria}>
      <ul class="site-nav__list">
        {navItems.map((item) => (
          <>
            <li class="site-nav__item">
              <a href={item.href} class="site-nav__link">
                <span class="site-nav__num">{item.num}</span>
                <span class="site-nav__label">{item.label}</span>
              </a>
            </li>
            {item.key === 'products' && (
              <li class="site-nav__item site-nav__item--talent">
                <a
                  href={talentHref}
                  class="site-nav__link site-nav__link--talent"
                  aria-label={i18n.header.nav.talent_aria}
                >
                  <Image
                    src={talentLogo3to1}
                    alt=""
                    class="site-nav__talent-logo site-nav__talent-logo--wide"
                    loading="eager"
                  />
                  <Image
                    src={talentLogo1to1}
                    alt=""
                    class="site-nav__talent-logo site-nav__talent-logo--square"
                    loading="eager"
                  />
                  <span class="site-nav__label site-nav__label--talent" aria-hidden="true">
                    {i18n.header.nav.talent_label}
                  </span>
                </a>
              </li>
            )}
          </>
        ))}
        <li class="site-nav__item site-nav__item--locale">
          <a
            href={altLocalePath}
            id="locale-switch"
            class="site-nav__link site-nav__link--locale"
            data-current-locale={locale}
            data-suggested-title={i18n.header.switch_locale_suggested_tooltip}
            aria-label={i18n.header.switch_locale_aria}
          >
            <span class:list={['site-nav__glyph', isJa ? null : 'site-nav__glyph--ja']} aria-hidden="true">
              {isJa ? 'A' : 'あ'}
            </span>
            <span class="site-nav__label">{i18n.header.switch_locale_label}</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // ブラウザ言語が現在表示中の言語と違う時、 切替ボタンを軽く強調
  // (= dot 表示 + title tooltip 設定)。 自動 redirect は行わない (= UX 阻害回避)
  const link = document.getElementById('locale-switch');
  if (link) {
    const current = link.dataset.currentLocale;
    const browserLang = (navigator.language || '').split('-')[0];
    if (browserLang && current && browserLang !== current && (browserLang === 'ja' || browserLang === 'en')) {
      link.setAttribute('data-suggested', 'true');
      const tooltip = link.dataset.suggestedTitle;
      if (tooltip) link.setAttribute('title', tooltip);
    }
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(245, 236, 215, 0.88);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border-bottom: 1px solid var(--color-paper-fold);
  }

  .site-header__inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0.875rem clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    color: var(--color-ink-deep);
  }
  .site-header__brand:hover {
    text-decoration: none;
    color: var(--color-ink-deep);
  }

  /* brand mark wrapper — 元 PNG が 256x256 で兎猫が中心に小さく描かれており、
     44x44 円形クリップで余白 (= 四隅) が目立つ。 wrapper を 44px 円形 + overflow:hidden
     にして、 内部 img を transform: scale で拡大することで円の中身を埋める。
     wrapper 自体の外形は 44px のまま、 内部だけ拡大される。 */
  .site-header__mark-wrap {
    display: inline-block;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-paper-fold);
    background-color: var(--color-paper-warm);
    overflow: hidden;
    flex-shrink: 0;
  }
  .site-header__mark {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.22);
    transform-origin: center;
  }

  .site-header__wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    gap: 0.125rem;
  }

  .site-header__name-ja {
    font-family: var(--font-serif-jp);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    color: var(--color-ink-deep);
  }

  .site-header__name-en {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint);
  }

  /* 2026-05-26 user fb (iPhone SE 3 = 375px viewport で 4 ナビ項目が全て 2 行折返し +
     talent ロゴ hide で「不格好」): ナビ全体は flex-wrap で折返し許可 + 右寄せ、
     ナビ項目の文字単位改行は `.site-nav__label` の `white-space: nowrap` で禁止。
     これで「ミッション / プロダクト / talent / 事業概要」 の 4 項目を 1 行目右寄せ +
     「お問合せ / [A] / EN」 の locale 系を 2 行目右寄せ、 が SE 3 帯域で成立する。
     row-gap は折返し時の縦間隔のみ控えめ (= column-gap は既存 clamp 値を流用)。 */
  .site-nav__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    column-gap: clamp(1rem, 2.5vw, 2.25rem);
    row-gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    text-decoration: none;
    color: var(--color-ink-soft);
    position: relative;
    padding: 0.25rem 0;
    transition: color 200ms ease;
  }
  .site-nav__link:hover {
    color: var(--color-ink-deep);
    text-decoration: none;
  }

  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background-color: var(--color-olive-deep);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 280ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .site-nav__link:hover::after,
  .site-nav__link:focus-visible::after {
    transform: scaleX(1);
  }

  .site-nav__num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--color-olive);
    font-weight: 500;
  }

  .site-nav__label {
    font-family: var(--font-sans-jp);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    /* 文字単位改行禁止 (= 「ミッショ\nン」 「お問合\nせ」 のような不格好な折返し抑止)。
       ナビ全体は `.site-nav__list` 側の flex-wrap で行折返しする運用、 個別ラベルは
       1 語まとめて改行される。 */
    white-space: nowrap;
  }

  /* talent ロゴ nav 項目 — 主力プロダクトへの直接導線。
     02 プロダクトに密接配置 (= 「products カテゴリの代表 1 つ」 印象)、
     border-radius pill + 紙折れ色 1px 枠 + 薄 shadow でボタン化、
     ロゴ自体の白背景 (= #fdf6ec) がサイト paper-warm から浮く問題を
     角丸ボタンとしてまとめる方向で解決。
     desktop は 3:1 (= 金貨 + 「Talent」 横書き)、 mobile 640px↓ は
     1:1 (= 金貨単体に Talent 文字下中央) を 32px で表示。
     label テキストは常に visually-hidden、 アクセシブル名は <a aria-label> 一本。 */
  .site-nav__item--talent {
    /* 02 プロダクトとの距離を詰める。 nav の gap (= clamp(1rem, 2.5vw, 2.25rem))
       を打ち消し、 talent と前項目の間を 0.5rem に固定 (= 「products の一つ」 印象) */
    margin-left: calc(-1 * clamp(1rem, 2.5vw, 2.25rem) + 0.5rem);
  }
  .site-nav__link--talent {
    align-items: center;
    padding: 0;
  }
  .site-nav__talent-logo {
    display: block;
    height: 36px;
    width: auto;
    border-radius: 18px;
    border: 1px solid var(--color-paper-fold);
    background-color: #fdf6ec;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(255, 255, 255, 0.3) inset;
    opacity: 0.94;
    transition: opacity 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .site-nav__talent-logo--square {
    /* mobile 切替用、 desktop は隠す。 高さは width 32px に揃える (= 1:1 比率) */
    display: none;
    height: 32px;
    width: 32px;
    border-radius: 50%;
  }
  .site-nav__link--talent:hover .site-nav__talent-logo,
  .site-nav__link--talent:focus-visible .site-nav__talent-logo {
    opacity: 1;
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(74, 90, 47, 0.18), 0 0 0 1px rgba(255, 255, 255, 0.3) inset;
  }
  /* hover の下線装飾は logo に被ると視覚ノイズなので無効化 */
  .site-nav__link--talent::after {
    display: none;
  }
  .site-nav__label--talent {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  /* locale switch glyph — IME 切替ボタン風に、 切替先言語の代表文字を
     正方形・角丸 border で囲って表示。 言語コードのすぐ左に密接配置。
     色は --color-olive で統一、 主張しすぎない */
  .site-nav__glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    margin-right: 0.3rem;
    border: 1px solid var(--color-olive);
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    line-height: 1;
    color: var(--color-olive);
    letter-spacing: 0;
  }
  .site-nav__glyph--ja {
    font-family: var(--font-serif-jp);
    font-size: 0.78rem;
  }

  /* locale switch link — Accept-Language ヒント装飾。 ブラウザ言語と現在表示
     言語が違う時、 glyph box を「点灯」 させて active 状態を示す (= IME の
     active 入力ソースが塗りつぶしになるメタファー)。 自動 redirect はしない */
  .site-nav__link--locale {
    align-items: center;
  }
  .site-nav__link--locale[data-suggested="true"] {
    color: var(--color-ink-deep);
  }
  .site-nav__link--locale[data-suggested="true"] .site-nav__glyph {
    background-color: var(--color-olive);
    color: var(--color-paper-warm);
    border-color: var(--color-olive);
  }

  /* モバイル — 番号は隠す、 ラベルは短縮 */
  @media (max-width: 640px) {
    .site-header__inner {
      padding: 0.75rem 1.25rem;
      gap: 1rem;
    }
    .site-header__mark-wrap {
      width: 36px;
      height: 36px;
    }
    .site-header__name-ja {
      font-size: 0.95rem;
    }
    .site-header__name-en {
      font-size: 0.65rem;
    }
    .site-nav__list {
      gap: 0.875rem;
    }
    .site-nav__num {
      display: none;
    }
    .site-nav__label {
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
    }
    /* mobile: 3:1 ロゴを隠し、 1:1 ロゴ 32px (= 金貨単体に「Talent」 文字下中央) 表示 */
    .site-nav__talent-logo--wide {
      display: none;
    }
    .site-nav__talent-logo--square {
      display: block;
    }
    /* 02 プロダクトとの距離詰め — mobile の gap (= 0.875rem) を打ち消し 0.4rem に */
    .site-nav__item--talent {
      margin-left: -0.475rem;
    }
  }

  /* 420px↓ では brand wordmark を隠して左 column を mark のみに絞る帯域。
     旧: talent 項目も hide していたが、 2026-05-26 user fb で nav 全体を flex-wrap
     右寄せ折返し化 → SE 3 (= 375px) でも talent ロゴが 1 行目に収まる設計に変更したため
     talent 項目 hide は撤去。 wordmark は折返し前提でも左 column を圧迫するため依然 hide。

     さらに 2026-05-26 user fb: nav 2 行折返しで header 縦幅が増えた帯域では mark も
     大きく見せたいため、 brand container を `align-self: stretch` で inner の縦高さに
     追従させ、 mark-wrap を `height: 100%` + `aspect-ratio: 1` で content 高さに揃う
     正方形に。 width は固定値撤去で aspect-ratio から intrinsic 算出。 */
  @media (max-width: 420px) {
    .site-header__wordmark {
      display: none;
    }
    .site-header__brand {
      align-self: stretch;
    }
    .site-header__mark-wrap {
      width: auto;
      height: 100%;
      aspect-ratio: 1 / 1;
    }
  }
</style>
