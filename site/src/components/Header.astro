---
// ChatteLapin Header — 古典書物の扉ページ × シャープなナビゲーション
// 翻訳テキストは data/i18n/{ja,en}.yaml に集約。 locale は Astro.currentLocale で切替。
import { Image } from 'astro:assets';
import mark from '../assets/chattelapin-mark.png';
import jaDict from '../../../data/i18n/ja.yaml';
import enDict from '../../../data/i18n/en.yaml';

const locale = Astro.currentLocale || 'ja';
const isJa = locale === 'ja';
const i18n = isJa ? jaDict : enDict;
const homeHref = isJa ? '/' : '/en';

// 現在 page の言語切替先 URL を算出 (= /products/talent <-> /en/products/talent 等)
// 切替ボタンを押したら現在 page を維持して言語だけ切り替わる
// Astro.url.pathname は `format: 'file'` 設定下では `.html` 拡張子付きになるので除去
const rawPath = Astro.url.pathname;
const pathname = rawPath.replace(/\.html$/, '').replace(/\/index$/, '') || '/';
const altLocalePath = isJa
  ? (pathname === '/' ? '/en' : `/en${pathname}`)
  : (pathname.replace(/^\/en/, '') || '/');

const navItems = [
  { num: '01', label: i18n.header.nav.mission, href: `${homeHref}#mission` },
  { num: '02', label: i18n.header.nav.products, href: `${homeHref}#products` },
  { num: '03', label: i18n.header.nav.about, href: `${homeHref}#about` },
  { num: '04', label: i18n.header.nav.contact, href: `${homeHref}#contact` },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={homeHref} class="site-header__brand" aria-label={i18n.header.brand_aria}>
      <Image
        src={mark}
        alt=""
        width={44}
        height={44}
        densities={[1, 2, 3]}
        format="webp"
        quality={85}
        loading="eager"
        class="site-header__mark"
      />
      <span class="site-header__wordmark">
        <span class="site-header__name-ja">シャラパン</span>
        <span class="site-header__name-en">Chatte Lapin</span>
      </span>
    </a>

    <nav class="site-nav" aria-label={i18n.header.nav_aria}>
      <ol class="site-nav__list">
        {navItems.map((item) => (
          <li class="site-nav__item">
            <a href={item.href} class="site-nav__link">
              <span class="site-nav__num">{item.num}</span>
              <span class="site-nav__label">{item.label}</span>
            </a>
          </li>
        ))}
        <li class="site-nav__item site-nav__item--locale">
          <a
            href={altLocalePath}
            id="locale-switch"
            class="site-nav__link site-nav__link--locale"
            data-current-locale={locale}
            data-suggested-title={i18n.header.switch_locale_suggested_tooltip}
            aria-label={i18n.header.switch_locale_aria}
          >
            <span class="site-nav__locale-dot" aria-hidden="true"></span>
            <span class:list={['site-nav__glyph', isJa ? null : 'site-nav__glyph--ja']} aria-hidden="true">
              {isJa ? 'A' : 'あ'}
            </span>
            <span class="site-nav__label">{i18n.header.switch_locale_label}</span>
          </a>
        </li>
      </ol>
    </nav>
  </div>
</header>

<script>
  // ブラウザ言語が現在表示中の言語と違う時、 切替ボタンを軽く強調
  // (= dot 表示 + title tooltip 設定)。 自動 redirect は行わない (= UX 阻害回避)
  const link = document.getElementById('locale-switch');
  if (link) {
    const current = link.dataset.currentLocale;
    const browserLang = (navigator.language || '').split('-')[0];
    if (browserLang && current && browserLang !== current && (browserLang === 'ja' || browserLang === 'en')) {
      link.setAttribute('data-suggested', 'true');
      const tooltip = link.dataset.suggestedTitle;
      if (tooltip) link.setAttribute('title', tooltip);
    }
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(245, 236, 215, 0.88);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border-bottom: 1px solid var(--color-paper-fold);
  }

  .site-header__inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0.875rem clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    color: var(--color-ink-deep);
  }
  .site-header__brand:hover {
    text-decoration: none;
    color: var(--color-ink-deep);
  }

  .site-header__mark {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-paper-fold);
    background-color: var(--color-paper-warm);
  }

  .site-header__wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    gap: 0.125rem;
  }

  .site-header__name-ja {
    font-family: var(--font-serif-jp);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    color: var(--color-ink-deep);
  }

  .site-header__name-en {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint);
  }

  .site-nav__list {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    text-decoration: none;
    color: var(--color-ink-soft);
    position: relative;
    padding: 0.25rem 0;
    transition: color 200ms ease;
  }
  .site-nav__link:hover {
    color: var(--color-ink-deep);
    text-decoration: none;
  }

  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background-color: var(--color-olive-deep);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 280ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .site-nav__link:hover::after,
  .site-nav__link:focus-visible::after {
    transform: scaleX(1);
  }

  .site-nav__num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--color-olive);
    font-weight: 500;
  }

  .site-nav__label {
    font-family: var(--font-sans-jp);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
  }

  /* locale switch glyph — [A] / [あ] を切替先言語の代表文字として表示。
     トーンは site-nav__num (= 01/02/03/04) と揃え、 mono + olive + 小サイズ。
     ja グリフ「あ」 だけは serif-jp に切替えて字形を整える */
  .site-nav__glyph {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--color-olive);
    font-weight: 500;
    margin-right: 0.4rem;
    white-space: nowrap;
  }
  .site-nav__glyph--ja {
    font-family: var(--font-serif-jp);
    font-size: 0.78rem;
    letter-spacing: 0;
  }
  .site-nav__glyph::before {
    content: "[";
    opacity: 0.55;
    margin-right: 0.08em;
  }
  .site-nav__glyph::after {
    content: "]";
    opacity: 0.55;
    margin-left: 0.08em;
  }

  /* locale switch link — Accept-Language ヒント装飾 (= dot は通常非表示、 suggested 時のみ可視) */
  .site-nav__locale-dot {
    display: none;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-olive);
    margin-right: 0.45rem;
    flex-shrink: 0;
    align-self: center;
  }
  .site-nav__link--locale {
    align-items: center;
  }
  .site-nav__link--locale[data-suggested="true"] {
    color: var(--color-ink-deep);
  }
  .site-nav__link--locale[data-suggested="true"] .site-nav__locale-dot {
    display: inline-block;
    animation: locale-dot-pulse 2.4s ease-in-out infinite;
  }
  @keyframes locale-dot-pulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav__link--locale[data-suggested="true"] .site-nav__locale-dot {
      animation: none;
      opacity: 0.85;
    }
  }

  /* モバイル — 番号は隠す、 ラベルは短縮 */
  @media (max-width: 640px) {
    .site-header__inner {
      padding: 0.75rem 1.25rem;
      gap: 1rem;
    }
    .site-header__mark {
      width: 36px;
      height: 36px;
    }
    .site-header__name-ja {
      font-size: 0.95rem;
    }
    .site-header__name-en {
      font-size: 0.65rem;
    }
    .site-nav__list {
      gap: 0.875rem;
    }
    .site-nav__num {
      display: none;
    }
    .site-nav__label {
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
    }
  }

  @media (max-width: 420px) {
    .site-header__wordmark {
      display: none;
    }
  }
</style>
