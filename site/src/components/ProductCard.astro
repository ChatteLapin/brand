---
// プロダクトカード
// 4 プロダクト (= talent / business / brand / volt) を visual 統一表示

interface Props {
  name: string;
  tagline: string;
  href: string;
  badge?: string;
  size?: 'large' | 'medium' | 'small';
}

const { name, tagline, href, badge, size = 'medium' } = Astro.props;

const sizeClasses = {
  large: 'p-8 md:p-10',
  medium: 'p-6',
  small: 'p-5',
};

const titleSizeClasses = {
  large: 'text-3xl md:text-4xl',
  medium: 'text-2xl',
  small: 'text-xl',
};
---

<a
  href={href}
  class={`block rounded-lg border border-[color:var(--color-line)] bg-white/60 no-underline transition hover:border-[color:var(--color-accent-soft)] hover:shadow-md ${sizeClasses[size]}`}
>
  <div class="flex items-start justify-between">
    <h3 class={`font-serif tracking-wide text-[color:var(--color-ink)] ${titleSizeClasses[size]}`}>{name}</h3>
    {badge && (
      <span class="rounded-full bg-[color:var(--color-accent-soft)]/30 px-3 py-1 text-xs font-semibold text-[color:var(--color-accent)]">
        {badge}
      </span>
    )}
  </div>
  <p class="mt-3 text-[color:var(--color-ink-soft)]">{tagline}</p>
</a>
