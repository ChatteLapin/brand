---
// プロダクトカード — 編集記事風 (= 番号 + タイトル + バッジ + tagline + 矢印リンク)
// logoSrc 渡された場合は card 全体を 2 列 grid 化し、 右に円形クリップした
// ロゴ (= 多言語と「Talent」 文字を切り落とし、 中央の金貨 + Ŧ + bas-relief
// だけを浮かび上がらせる構図) を配置する。
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  tagline: string;
  href: string;
  badge?: string;
  size?: 'large' | 'medium' | 'small';
  number?: string;
  variant?: 'primary' | 'satellite';
  logoSrc?: ImageMetadata;
}

const {
  name,
  tagline,
  href,
  badge,
  size = 'medium',
  number,
  variant = 'satellite',
  logoSrc,
} = Astro.props;

const sizeClasses = {
  large: 'card-large',
  medium: 'card-medium',
  small: 'card-small',
};
---

<a href={href} class={`editorial-card ${sizeClasses[size]} variant-${variant}`}>
  <div class="editorial-card__main">
    {number && <span class="editorial-card__num">{number}</span>}

    <div class="editorial-card__head">
      <h3 class="editorial-card__title">{name}</h3>
      {badge && (
        <span class={`editorial-card__badge ${variant === 'primary' ? 'editorial-card__badge--primary' : ''}`}>
          {badge}
        </span>
      )}
    </div>

    <p class="editorial-card__tagline">{tagline}</p>

    <span class="editorial-card__arrow">
      Read more
    </span>
  </div>

  {logoSrc && (
    <Image
      src={logoSrc}
      alt=""
      class="editorial-card__logo"
      loading="lazy"
    />
  )}
</a>

<style>
  .card-large {
    padding: 2.5rem 2.5rem 2rem;
  }
  .card-medium {
    padding: 2rem 2rem 1.75rem;
  }
  .card-small {
    padding: 1.5rem 1.5rem 1.25rem;
  }

  .card-large .editorial-card__title {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
  }
  .card-medium .editorial-card__title {
    font-size: 1.375rem;
  }
  .card-small .editorial-card__title {
    font-size: 1.125rem;
  }

  /* logoSrc ありの card は全体を 2 列 grid 化 (= main + 右ロゴ)。 logo なしカードは
     既存の block flow (= main の中身を直下に並べる) を維持。 */
  .editorial-card:has(.editorial-card__logo) {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  .editorial-card__main {
    min-width: 0;
  }

  .editorial-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* product 固有ロゴ — talent の 1:1 ロゴを円形クリップ (= border-radius: 50%) で
     金貨 + Ŧ + chattelapin bas-relief だけを浮かび上がらせる。 1:1 SVG の中央付近に
     金貨があり、 周囲の多言語散布と下中央の「Talent」 文字は円外で自然に消える。
     視覚的に「主力商品の brand mark」 としてカード右側に存在感を持たせる。
     mobile (640px↓) では card の上下 padding を圧迫するため隠す (= site Header の
     pill ロゴで talent ブランドは既に提示済)。 */
  .editorial-card__logo {
    height: clamp(96px, 12vw, 140px);
    width: clamp(96px, 12vw, 140px);
    border-radius: 50%;
    border: 1px solid var(--color-paper-fold);
    background-color: #fdf6ec;
    object-fit: cover;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04), 0 4px 16px rgba(74, 90, 47, 0.08);
    transition: transform 240ms ease, box-shadow 240ms ease;
  }
  .card-medium .editorial-card__logo,
  .card-small .editorial-card__logo {
    height: clamp(72px, 10vw, 96px);
    width: clamp(72px, 10vw, 96px);
  }
  .editorial-card:hover .editorial-card__logo {
    transform: translateY(-2px);
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.04), 0 8px 22px rgba(74, 90, 47, 0.14);
  }

  @media (max-width: 640px) {
    .editorial-card:has(.editorial-card__logo) {
      grid-template-columns: 1fr;
    }
    .editorial-card__logo {
      display: none;
    }
  }

  .variant-primary {
    background-color: rgba(255, 252, 245, 0.7);
    border-color: var(--color-olive);
    border-width: 1px;
  }

  .variant-primary:hover {
    border-color: var(--color-olive-deep);
    background-color: rgba(255, 252, 245, 0.95);
  }

  .card-large .editorial-card__tagline {
    font-size: 1rem;
    line-height: 1.95;
    max-width: 56ch;
  }
</style>
