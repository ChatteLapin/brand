---
// プロダクトカード — 編集記事風 (= 番号 + タイトル + バッジ + tagline + 矢印リンク)
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  tagline: string;
  href: string;
  badge?: string;
  size?: 'large' | 'medium' | 'small';
  number?: string;
  variant?: 'primary' | 'satellite';
  logoSrc?: ImageMetadata;
}

const {
  name,
  tagline,
  href,
  badge,
  size = 'medium',
  number,
  variant = 'satellite',
  logoSrc,
} = Astro.props;

const sizeClasses = {
  large: 'card-large',
  medium: 'card-medium',
  small: 'card-small',
};
---

<a href={href} class={`editorial-card ${sizeClasses[size]} variant-${variant}`}>
  {number && <span class="editorial-card__num">{number}</span>}

  <div class="editorial-card__head">
    {logoSrc && (
      <Image
        src={logoSrc}
        alt=""
        class="editorial-card__logo"
        loading="lazy"
      />
    )}
    <h3 class="editorial-card__title">{name}</h3>
    {badge && (
      <span class={`editorial-card__badge ${variant === 'primary' ? 'editorial-card__badge--primary' : ''}`}>
        {badge}
      </span>
    )}
  </div>

  <p class="editorial-card__tagline">{tagline}</p>

  <span class="editorial-card__arrow">
    Read more
  </span>
</a>

<style>
  .card-large {
    padding: 2.5rem 2.5rem 2rem;
  }
  .card-medium {
    padding: 2rem 2rem 1.75rem;
  }
  .card-small {
    padding: 1.5rem 1.5rem 1.25rem;
  }

  .card-large .editorial-card__title {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
  }
  .card-medium .editorial-card__title {
    font-size: 1.375rem;
  }
  .card-small .editorial-card__title {
    font-size: 1.125rem;
  }

  .editorial-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  /* logoSrc ありの card のみ中央揃え (= ロゴと title を視覚的に揃える)。
     logo なしカード (= volt/business/brand) は flex-start を維持し、 title が
     2 行に折れた時に badge が「title 先頭行」 に揃う既存挙動を保持 */
  .editorial-card__head:has(.editorial-card__logo) {
    align-items: center;
  }

  /* product 固有ロゴ — talent の 1:1 金貨ロゴ等。 card head の左に title と
     並んで配置。 サイズは card サイズに連動 (= large は 64px、 medium は 48px)。
     pill 形ボタン化は site Header と同調 (= 紙折れ枠 + 紙色背景 + 軽 shadow)。
     title「Talent」 文字はロゴ内にもあるが、 h3 テキストは a11y / SEO のため保持。 */
  .editorial-card__logo {
    flex-shrink: 0;
    height: 64px;
    width: 64px;
    border-radius: 50%;
    border: 1px solid var(--color-paper-fold);
    background-color: #fdf6ec;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }
  .card-medium .editorial-card__logo,
  .card-small .editorial-card__logo {
    height: 48px;
    width: 48px;
  }
  /* head の中で logo 左 + title 中央 + badge 右 になるよう、 title に flex grow */
  .editorial-card__logo + .editorial-card__title {
    flex: 1 1 auto;
  }

  .variant-primary {
    background-color: rgba(255, 252, 245, 0.7);
    border-color: var(--color-olive);
    border-width: 1px;
  }

  .variant-primary:hover {
    border-color: var(--color-olive-deep);
    background-color: rgba(255, 252, 245, 0.95);
  }

  .card-large .editorial-card__tagline {
    font-size: 1rem;
    line-height: 1.95;
    max-width: 56ch;
  }
</style>
