---
// ChatteLapin Footer — 古典書物のコロフォン (= 末尾発行記録) 風
// 翻訳テキストは data/i18n/{ja,en}.yaml に集約。 colophon は HTML (= <strong>, <br>) を含むため set:html で render。
import jaDict from '../../../data/i18n/ja.yaml';
import enDict from '../../../data/i18n/en.yaml';
// リンク・帰属・© 表記の SoT (= 統一フッター規約、 brand/guidelines.md 参照)
import footerData from '../../../data/footer.yaml';

const year = new Date().getFullYear();
const since = footerData.copyright.since;
const copyYears = since && since < year ? `${since}–${year}` : `${year}`;
const locale = Astro.currentLocale || 'ja';
const isJa = locale === 'ja';
const i18n = isJa ? jaDict : enDict;
const homeHref = isJa ? '/' : '/en';

// 公開中の姉妹サービス相互リンク (= 自分自身は除外)
const siblingServices = (footerData.services || []).filter((s) => s.id !== 'brand');

const navItems = [
  { label: i18n.header.nav.mission, href: `${homeHref}#mission` },
  { label: i18n.header.nav.products, href: `${homeHref}#products` },
  { label: i18n.header.nav.about, href: `${homeHref}#about` },
  { label: i18n.header.nav.contact, href: `${homeHref}#contact` },
];
---

<footer class="site-footer">
  <div class="site-footer__rule" aria-hidden="true">
    <span class="site-footer__rule-glyph">❦</span>
  </div>

  <div class="site-footer__inner">
    <div class="site-footer__colophon">
      <p class="site-footer__colophon-label">{i18n.footer.colophon_label}</p>
      <p class="site-footer__colophon-text" set:html={i18n.footer.colophon_text}></p>
    </div>

    <nav class="site-footer__nav" aria-label={i18n.footer.nav_aria}>
      <p class="site-footer__nav-label">{i18n.footer.nav_label_navigation}</p>
      <ul class="site-footer__nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__elsewhere">
      <p class="site-footer__nav-label">{i18n.footer.nav_label_elsewhere}</p>
      <ul class="site-footer__nav-list">
        {siblingServices.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener">{isJa ? s.name.ja : s.name.en}</a>
          </li>
        ))}
        <li>
          <a href={footerData.github.org} target="_blank" rel="noopener">
            {i18n.footer.github_org}
          </a>
        </li>
        <li>
          <a href={footerData.github.contact} target="_blank" rel="noopener">
            {i18n.footer.issues_link}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="site-footer__base">
    <p class="site-footer__copy">
      <span class="site-footer__year">{copyYears}</span>
      <span aria-hidden="true">·</span>
      <span>{i18n.footer.copy_name}</span>
      <span aria-hidden="true">·</span>
      <span class="site-footer__rights">{i18n.footer.rights}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding-top: 4rem;
    padding-bottom: 2.5rem;
    border-top: 1px solid var(--color-paper-fold);
    background-color: rgba(235, 224, 196, 0.35);
    position: relative;
  }

  .site-footer__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .site-footer__rule-glyph {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-olive);
    opacity: 0.8;
    padding: 0 1.5rem;
    background-color: var(--color-paper);
    border: 1px solid var(--color-paper-fold);
    border-radius: 50%;
    width: 3.5rem;
    height: 3.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 760px) {
    .site-footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 3.5rem;
    }
  }

  .site-footer__colophon-label,
  .site-footer__nav-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-paper-fold);
    font-weight: 500;
  }

  .site-footer__colophon-text {
    font-family: var(--font-serif-jp);
    font-size: 0.875rem;
    line-height: 2;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
    margin: 0;
  }
  .site-footer__colophon-text strong {
    font-weight: 600;
    color: var(--color-ink-deep);
  }

  .site-footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    font-size: 0.875rem;
  }

  .site-footer__nav-list a {
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 180ms ease;
  }
  .site-footer__nav-list a:hover {
    color: var(--color-blush-deep);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer__base {
    max-width: 1200px;
    margin: 4rem auto 0;
    padding: 1.5rem clamp(1.5rem, 5vw, 3rem) 0;
    border-top: 1px solid var(--color-paper-fold);
  }

  .site-footer__copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: center;
    justify-content: center;
  }
</style>
