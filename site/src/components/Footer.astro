---
// ChatteLapin Footer — 古典書物のコロフォン (= 末尾発行記録) 風

const year = new Date().getFullYear();
const locale = Astro.currentLocale || 'ja';
const isJa = locale === 'ja';
const homeHref = isJa ? '/' : '/en';

const labels = isJa
  ? {
      navAria: 'フッターナビゲーション',
      nav: [
        { label: 'ミッション', href: `${homeHref}#mission` },
        { label: 'プロダクト', href: `${homeHref}#products` },
        { label: '事業概要', href: `${homeHref}#about` },
        { label: 'お問合せ', href: `${homeHref}#contact` },
      ],
      githubOrg: 'GitHub Organization',
      issuesLink: 'お問合せ Issues',
      copyName: 'ChatteLapin · シャラパン',
      rights: 'All rights reserved.',
    }
  : {
      navAria: 'Footer navigation',
      nav: [
        { label: 'Mission', href: `${homeHref}#mission` },
        { label: 'Products', href: `${homeHref}#products` },
        { label: 'About', href: `${homeHref}#about` },
        { label: 'Contact', href: `${homeHref}#contact` },
      ],
      githubOrg: 'GitHub Organization',
      issuesLink: 'Contact via Issues',
      copyName: 'ChatteLapin',
      rights: 'All rights reserved.',
    };
---

<footer class="site-footer">
  <div class="site-footer__rule" aria-hidden="true">
    <span class="site-footer__rule-glyph">❦</span>
  </div>

  <div class="site-footer__inner">
    <div class="site-footer__colophon">
      <p class="site-footer__colophon-label">Colophon</p>
      {isJa ? (
        <p class="site-footer__colophon-text">
          本書は <strong>シャラパン (ChatteLapin)</strong> の公式サイトです。 <br />
          2026 年 5 月、 熱海税務署管轄の個人事業として開業。 <br />
          ソフトウェア開発業として、 青色申告 65 万円控除のもとに、 <br />
          Astro と Tailwind を用い、 静かに組版されました。
        </p>
      ) : (
        <p class="site-footer__colophon-text">
          The official site of <strong>ChatteLapin</strong> (Japanese: シャラパン). <br />
          Opened in May 2026 as a sole proprietorship under Atami Tax Office, Japan. <br />
          Operated under blue-form taxation with a 650,000 JPY deduction, <br />
          and quietly typeset with Astro and Tailwind.
        </p>
      )}
    </div>

    <nav class="site-footer__nav" aria-label={labels.navAria}>
      <p class="site-footer__nav-label">Navigation</p>
      <ul class="site-footer__nav-list">
        {labels.nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__elsewhere">
      <p class="site-footer__nav-label">Elsewhere</p>
      <ul class="site-footer__nav-list">
        <li>
          <a href="https://github.com/ChatteLapin" target="_blank" rel="noopener">
            {labels.githubOrg}
          </a>
        </li>
        <li>
          <a href="https://github.com/ChatteLapin/brand/issues/new" target="_blank" rel="noopener">
            {labels.issuesLink}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="site-footer__base">
    <p class="site-footer__copy">
      <span class="site-footer__year">{year}</span>
      <span aria-hidden="true">·</span>
      <span>{labels.copyName}</span>
      <span aria-hidden="true">·</span>
      <span class="site-footer__rights">{labels.rights}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding-top: 4rem;
    padding-bottom: 2.5rem;
    border-top: 1px solid var(--color-paper-fold);
    background-color: rgba(235, 224, 196, 0.35);
    position: relative;
  }

  .site-footer__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .site-footer__rule-glyph {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-olive);
    opacity: 0.8;
    padding: 0 1.5rem;
    background-color: var(--color-paper);
    border: 1px solid var(--color-paper-fold);
    border-radius: 50%;
    width: 3.5rem;
    height: 3.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 760px) {
    .site-footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 3.5rem;
    }
  }

  .site-footer__colophon-label,
  .site-footer__nav-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-paper-fold);
    font-weight: 500;
  }

  .site-footer__colophon-text {
    font-family: var(--font-serif-jp);
    font-size: 0.875rem;
    line-height: 2;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
    margin: 0;
  }
  .site-footer__colophon-text strong {
    font-weight: 600;
    color: var(--color-ink-deep);
  }

  .site-footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    font-size: 0.875rem;
  }

  .site-footer__nav-list a {
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 180ms ease;
  }
  .site-footer__nav-list a:hover {
    color: var(--color-blush-deep);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer__base {
    max-width: 1200px;
    margin: 4rem auto 0;
    padding: 1.5rem clamp(1.5rem, 5vw, 3rem) 0;
    border-top: 1px solid var(--color-paper-fold);
  }

  .site-footer__copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: center;
    justify-content: center;
  }
</style>
